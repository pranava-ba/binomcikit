# Consistent line endings across platforms: LF in the repository AND the working
# tree, on every OS. Stops the "LF will be replaced by CRLF" warnings on Windows
# and prevents noisy line-ending diffs between sessions / operating systems.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.pdf binary
*.gz  binary
*.zip binary
*.ico binary
